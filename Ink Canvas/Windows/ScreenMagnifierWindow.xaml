<Window
    x:Class="Ink_Canvas.Windows.ScreenMagnifierWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="420"
    Height="280"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">
    <Border
        BorderBrush="#FFF7C948"
        BorderThickness="3"
        CornerRadius="4"
        SnapsToDevicePixels="True">
        <Grid ClipToBounds="True" Background="#FF101317">
            <Image
                x:Name="ImageViewport"
                Margin="0,10,0,42"
                Stretch="Fill"
                MouseLeftButtonDown="DragHandle_MouseLeftButtonDown" />

            <Border
                x:Name="TopResizeHandle"
                Height="10"
                VerticalAlignment="Top"
                Background="#10FFFFFF"
                Cursor="SizeNS"
                MouseLeftButtonDown="TopResizeHandle_MouseLeftButtonDown"
                MouseLeftButtonUp="TopResizeHandle_MouseLeftButtonUp"
                MouseMove="TopResizeHandle_MouseMove" />

            <Border
                x:Name="LeftResizeHandle"
                Width="12"
                HorizontalAlignment="Left"
                Background="#20FFFFFF"
                Cursor="SizeWE"
                MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                MouseMove="ResizeHandle_MouseMove"
                Tag="Left" />

            <Border
                x:Name="RightResizeHandle"
                Width="12"
                HorizontalAlignment="Right"
                Background="#20FFFFFF"
                Cursor="SizeWE"
                MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                MouseMove="ResizeHandle_MouseMove"
                Tag="Right" />

            <Border
                Height="42"
                VerticalAlignment="Bottom"
                Background="#CC1F2937">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Cursor="SizeAll"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#FFF9FAFB"
                        Text="⣿"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown" />

                    <Button
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="减小放大倍率"
                        Background="#FF374151"
                        BorderBrush="#FFF9FAFB"
                        BorderThickness="1"
                        Click="BtnZoomOut_Click"
                        Content="-"
                        Foreground="#FFF9FAFB"
                        ToolTip="减小放大倍率" />

                    <Slider
                        x:Name="ZoomSlider"
                        Grid.Column="2"
                        AutomationProperties.Name="放大倍率滑块"
                        Minimum="1.5"
                        Maximum="5"
                        SmallChange="0.1"
                        LargeChange="0.5"
                        ToolTip="拖动调整放大倍率"
                        ValueChanged="ZoomSlider_ValueChanged"
                        Value="2.5"
                        VerticalAlignment="Center" />

                    <Button
                        Grid.Column="3"
                        Width="28"
                        Height="28"
                        Margin="8,0,8,0"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="增大放大倍率"
                        Background="#FF374151"
                        BorderBrush="#FFF9FAFB"
                        BorderThickness="1"
                        Click="BtnZoomIn_Click"
                        Content="+"
                        Foreground="#FFF9FAFB"
                        ToolTip="增大放大倍率" />

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            x:Name="TxtZoom"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Foreground="#FFF9FAFB"
                            FontWeight="SemiBold"
                            Text="2.5x" />
                        <Button
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="关闭放大镜"
                            Background="#FFB91C1C"
                            BorderBrush="#FFF9FAFB"
                            BorderThickness="1"
                            Click="BtnClose_Click"
                            Content="×"
                            Foreground="White"
                            ToolTip="关闭放大镜" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
