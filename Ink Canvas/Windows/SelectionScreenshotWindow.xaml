<Window x:Class="Ink_Canvas.Windows.SelectionScreenshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="选区截图"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized">
    <Grid x:Name="RootGrid" Background="#66000000" MouseLeftButtonDown="RootGrid_MouseLeftButtonDown" MouseMove="RootGrid_MouseMove" MouseLeftButtonUp="RootGrid_MouseLeftButtonUp" TouchDown="RootGrid_TouchDown" TouchMove="RootGrid_TouchMove" TouchUp="RootGrid_TouchUp">
        <Canvas x:Name="SelectionCanvas">
            <Path x:Name="SelectionPath" Stroke="#FF2D7DFF" StrokeThickness="2" Fill="#3D2D7DFF" Visibility="Collapsed" />
            <Rectangle x:Name="SelectionRect" Stroke="#FF2D7DFF" StrokeThickness="2" Fill="#3D2D7DFF" Visibility="Collapsed" />
        </Canvas>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,28,0,0"
                Background="#88000000"
                CornerRadius="10"
                Padding="16,8">
            <TextBlock x:Name="HintTextBlock"
                       FontSize="15"
                       Foreground="#FFF3F3F3"
                       Text="拖拽选择区域"
                       Opacity="0.95" />
        </Border>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,24"
                Background="#B3202020"
                CornerRadius="12"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnRectMode" Content="矩形选择" Width="86" Margin="0,0,8,0" Click="BtnRectMode_Click" />
                <Button x:Name="BtnFreeMode" Content="自由图形" Width="86" Margin="0,0,8,0" Click="BtnFreeMode_Click" />
                <Button x:Name="BtnCamera" Content="摄像头截图" Width="92" Margin="0,0,8,0" Click="BtnCamera_Click" />
                <ToggleButton x:Name="ToggleHideInk" Content="隐藏墨迹" Width="88" Margin="0,0,12,0" Checked="ToggleHideInk_Checked" Unchecked="ToggleHideInk_Unchecked" />

                <Button x:Name="BtnSaveDesktop" Content="保存到桌面" Width="96" Margin="0,0,8,0" Click="BtnSaveDesktop_Click" />
                <Button x:Name="BtnAddToBoard" Content="添加到白板" Width="96" Margin="0,0,8,0" Click="BtnAddToBoard_Click" />
                <Button x:Name="BtnCancel" Content="取消" Width="72" Click="BtnCancel_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
